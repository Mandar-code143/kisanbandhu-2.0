generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  phone         String    @unique
  passwordHash  String
  role          String    @default("FARMER") // Was enum Role
  isVerified    Boolean   @default(false)
  refreshToken  String?

  profile       Profile?
  farmer        Farmer?
  worker        Worker?
  contractor    Contractor?

  jobsPosted    Job[]             @relation("JobsPosted")
  applications  Application[]
  subscriptions Subscription[]
  payments      Payment[]
  transactions  Transaction[]     @relation("UserTransactions")
  ivrRequests   IvrRequest[]
  sentMessages  Message[]         @relation("SenderMessages")
  chatsAsUser1  Chat[]            @relation("ChatUser1")
  chatsAsUser2  Chat[]            @relation("ChatUser2")
  notifications Notification[]
  reviewsGiven  Review[]          @relation("Reviewer")
  reviewsReceived Review[]        @relation("ReviewedUser")
  rentals       Rental[]          @relation("Renter")
  equipment     Equipment[]
  otps          OTP[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String
  phone       String?
  avatar      String?
  bio         String?
  aadhaarLastFour String?
  languagePref String  @default("mr")

  district    String?
  taluka      String?
  village     String?
  pincode     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([district, taluka])
}

model Farmer {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  landSize    Float?
  cropTypes   String   @default("[]")

  produce     ProduceListing[]

  @@index([landSize])
}

model Worker {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  skills        String   @default("[]")
  experience    Int      @default(0)
  availability  Boolean  @default(true)
  dailyRate     Float?
  preferredTaluka String?

  @@index([skills])
  @@index([availability])
  @@index([preferredTaluka])
}

model Contractor {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName   String?
  licenseNumber String?
  specialization String   @default("[]")

  @@index([specialization])
}

model Job {
  id          String   @id @default(uuid())
  title       String
  description String
  jobType     String // Was enum JobType
  location    String
  salary      Float?
  salaryType  String // Was enum SalaryType
  slots       Int      @default(1)
  district    String?
  taluka      String?

  status      String @default("OPEN") // Was enum JobStatus

  postedById  String
  postedBy    User     @relation("JobsPosted", fields: [postedById], references: [id])

  applications Application[]
  ivrRequests  IvrRequest[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([status])
  @@index([jobType])
  @@index([location])
  @@index([district, taluka])
  @@index([postedById])
  @@index([createdAt])
}

model Application {
  id          String   @id @default(uuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  applicantId String
  applicant   User     @relation(fields: [applicantId], references: [id])

  status      String @default("PENDING") // Was enum AppStatus
  coverLetter String?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([jobId, applicantId])
  @@index([status])
  @@index([applicantId])
}

model ProduceListing {
  id          String   @id @default(uuid())
  farmerId    String
  farmer      Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  name        String
  category    String
  quantity    Float
  unit        String
  price       Float
  description String?
  imageUrl    String?
  district    String?
  taluka      String?

  status      String @default("ACTIVE") // Was enum ListingStatus

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([district, taluka])
  @@index([farmerId])
}

model Equipment {
  id          String   @id @default(uuid())
  name        String
  type        String
  description String?
  hourlyRate  Float?
  dailyRate   Float?
  imageUrl    String?

  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])

  isAvailable Boolean  @default(true)
  district    String?
  taluka      String?
  location    String

  rentals     Rental[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isAvailable])
  @@index([ownerId])
  @@index([district, taluka])
}

model Rental {
  id          String   @id @default(uuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  renterId    String
  renter      User     @relation("Renter", fields: [renterId], references: [id])

  startDate   DateTime
  endDate     DateTime
  totalAmount Float
  status      String @default("PENDING") // Was enum RentalStatus

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([renterId])
  @@index([equipmentId])
}

model Plan {
  id            String   @id @default(uuid())
  name          String   @unique
  price         Float
  durationDays  Int
  features      String // Stored as JSON string
  ivrCallsLimit Int      @default(0)
  isActive      Boolean  @default(true)

  subscriptions Subscription[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([price])
}

model Subscription {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  planId        String
  plan          Plan     @relation(fields: [planId], references: [id])

  status        String @default("ACTIVE") // Was enum SubStatus
  startDate     DateTime @default(now())
  endDate       DateTime
  autoRenew     Boolean  @default(false)
  razorpaySubId String?  @unique

  invoices      Invoice[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([endDate])
  @@index([status, endDate])
}

model Payment {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])

  amount            Float
  currency          String   @default("INR")
  status            String @default("PENDING") // Was enum PayStatus
  description       String?

  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  razorpaySignature String?

  subscriptionId    String?

  transactions      Transaction[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([razorpayOrderId])
}

model Invoice {
  id              String   @id @default(uuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  amount          Float
  status          String @default("PAID") // Was enum InvoiceStatus
  pdfUrl          String?
  invoiceNumber   String   @unique
  paidAt          DateTime?

  createdAt       DateTime @default(now())

  @@index([status])
  @@index([subscriptionId])
}

model Transaction {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation("UserTransactions", fields: [userId], references: [id])

  type          String // Was enum TransactionType
  amount        Float
  currency      String          @default("INR")
  status        String       @default("PENDING") // Was enum PayStatus
  description   String?
  referenceId   String?
  referenceType String?

  paymentId     String?
  payment       Payment?        @relation(fields: [paymentId], references: [id])

  createdAt     DateTime        @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model IvrRequest {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  jobId        String?
  job          Job?     @relation(fields: [jobId], references: [id])

  status       String @default("PENDING") // Was enum IvrStatus
  targetTaluka String?
  targetNumber String?
  workerType   String?
  message      String?

  adminNotes   String?
  callsMade    Int      @default(0)
  approvedBy   String?
  approvedAt   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

model Chat {
  id        String   @id @default(uuid())
  user1Id   String
  user1     User     @relation("ChatUser1", fields: [user1Id], references: [id])
  user2Id   String
  user2     User     @relation("ChatUser2", fields: [user2Id], references: [id])

  jobId     String?
  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  senderId  String
  sender    User     @relation("SenderMessages", fields: [senderId], references: [id])

  content   String
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String // Was enum NotificationType
  title     String
  message   String
  data      String? // Stored as JSON string
  readAt    DateTime?
  link      String?

  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
}

model Review {
  id          String   @id @default(uuid())
  reviewerId  String
  reviewer    User     @relation("Reviewer", fields: [reviewerId], references: [id])

  reviewedId  String
  reviewed    User     @relation("ReviewedUser", fields: [reviewedId], references: [id])

  rating      Int
  comment     String?
  jobId       String?

  createdAt   DateTime @default(now())

  @@unique([reviewerId, reviewedId, jobId])
  @@index([reviewedId])
  @@index([rating])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  metadata  String? // Stored as JSON string
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model AdminSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String // Stored as JSON string
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model OTP {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  code      String
  purpose   String // Was enum OTPPurpose
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)

  createdAt DateTime  @default(now())

  @@index([userId, purpose])
  @@index([code])
  @@index([expiresAt])
}
